/* ===== Reset & Base ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    display: flex;
    height: 100vh;
    overflow: hidden;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: #1a1a2e;
    color: #e0e0e0;
}

/* ===== Left Sidebar ===== */
#sidebar {
    width: 260px;
    min-width: 260px;
    background: #16213e;
    display: flex;
    flex-direction: column;
    border-right: 1px solid #0f3460;
    z-index: 10;
}

#sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border-bottom: 1px solid #0f3460;
}

#sidebar-header h2 {
    font-size: 18px;
    font-weight: 600;
    color: #e94560;
}

#btn-save-design {
    background: #0f3460;
    color: #e0e0e0;
    border: 1px solid #e94560;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s;
}

#btn-save-design:hover {
    background: #e94560;
    color: #fff;
}

#sidebar-hint {
    padding: 8px 16px;
    font-size: 12px;
    color: #888;
    font-style: italic;
}

#preset-grid {
    flex: 1;
    overflow-y: auto;
    padding: 8px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    align-content: start;
}

.preset-card {
    background: #1a1a2e;
    border: 2px solid #0f3460;
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.15s;
}

.preset-card:hover {
    border-color: #e94560;
    transform: scale(1.03);
}

.preset-card-thumb {
    width: 100%;
    aspect-ratio: 1;
    background: #0d1b3e;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.preset-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.preset-card-thumb canvas {
    width: 100%;
    height: 100%;
}

.preset-card-name {
    padding: 6px 8px;
    font-size: 11px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #ccc;
}

/* Color swatch grid for presets without thumbnails */
.preset-swatches {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    padding: 4px;
    width: 100%;
    aspect-ratio: 1;
}

.preset-swatch {
    border-radius: 2px;
}

#sidebar-footer {
    padding: 12px 16px;
    border-top: 1px solid #0f3460;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

#btn-refresh {
    width: 100%;
    background: #0f3460;
    color: #e0e0e0;
    border: none;
    border-radius: 6px;
    padding: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s;
}

#btn-refresh:hover {
    background: #1a4a8a;
}

#btn-preview {
    width: 100%;
    background: #e94560;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
}

#btn-preview:hover {
    background: #ff5a75;
}

/* ===== Main Canvas ===== */
#canvas-container {
    flex: 1;
    position: relative;
    overflow: hidden;
}

#renderCanvas {
    width: 100%;
    height: 100%;
    display: block;
    outline: none;
    touch-action: none;
    cursor: default;
}

/* ===== Mode Indicator ===== */
#mode-indicator {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(15, 52, 96, 0.9);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid #e94560;
    border-radius: 10px;
    padding: 8px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    z-index: 20;
    transition: background 0.3s;
    -webkit-user-select: none;
    user-select: none;
}

#mode-icon {
    font-size: 20px;
}

/* ===== Keyboard Hints ===== */
#keyboard-hints {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 16px;
    background: rgba(15, 52, 96, 0.8);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-radius: 10px;
    padding: 8px 20px;
    font-size: 13px;
    z-index: 20;
    -webkit-user-select: none;
    user-select: none;
}

#keyboard-hints span {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #aaa;
}

kbd {
    background: #e94560;
    color: #fff;
    border-radius: 4px;
    padding: 2px 7px;
    font-size: 12px;
    font-family: inherit;
    font-weight: 600;
}

/* ===== Loading Overlay ===== */
#loading-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 46, 0.95);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    z-index: 100;
    transition: opacity 0.5s;
}

#loading-overlay.hidden {
    opacity: 0;
    pointer-events: none;
}

#loading-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid #0f3460;
    border-top-color: #e94560;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

#loading-text {
    font-size: 15px;
    color: #888;
}

/* ===== Color Picker Popup ===== */
#color-picker-popup {
    position: absolute;
    z-index: 50;
    width: 240px;
    background: #16213e;
    border: 1px solid #e94560;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    overflow: hidden;
    transition: opacity 0.2s, transform 0.2s;
}

#color-picker-popup.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.9);
}

#picker-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: #0f3460;
    font-weight: 600;
    font-size: 14px;
    text-transform: capitalize;
}

#picker-close {
    background: none;
    border: none;
    color: #e94560;
    font-size: 18px;
    cursor: pointer;
    line-height: 1;
}

#picker-body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.picker-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.picker-section label {
    font-size: 12px;
    color: #888;
    font-weight: 500;
}

#picker-color {
    width: 100%;
    height: 36px;
    border: 1px solid #0f3460;
    border-radius: 6px;
    cursor: pointer;
    background: none;
    padding: 2px;
}

.file-btn {
    display: inline-block;
    background: #0f3460;
    color: #e0e0e0;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 13px;
    text-align: center;
    cursor: pointer;
    transition: background 0.2s;
}

.file-btn:hover {
    background: #1a4a8a;
}

.hidden-file-input {
    display: none;
}

.file-name {
    font-size: 11px;
    color: #666;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.reset-btn {
    width: 100%;
    background: transparent;
    color: #e94560;
    border: 1px solid #e94560;
    border-radius: 6px;
    padding: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
}

.reset-btn:hover {
    background: #e94560;
    color: #fff;
}

/* ===== Camera Position Panel ===== */
#btn-toggle-camera {
    position: absolute;
    top: 56px;
    right: 16px;
    z-index: 20;
    background: #0f3460;
    color: #e0e0e0;
    border: 1px solid #e94560;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
}

#btn-toggle-camera:hover {
    background: #e94560;
    color: #fff;
}

#camera-panel {
    position: absolute;
    top: 56px;
    right: 16px;
    width: 220px;
    background: rgba(22, 33, 62, 0.95);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid #0f3460;
    border-radius: 10px;
    padding: 12px;
    z-index: 25;
    font-size: 12px;
}

#camera-panel.hidden {
    display: none;
}

#camera-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 13px;
    color: #e94560;
    font-weight: 600;
}

#camera-panel-header button {
    background: #0f3460;
    color: #e0e0e0;
    border: none;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 11px;
    cursor: pointer;
    transition: background 0.2s;
    margin-left: 4px;
}

#camera-panel-header button:hover {
    background: #e94560;
    color: #fff;
}

#btn-close-camera {
    color: #e94560 !important;
    font-size: 14px !important;
}

.cam-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
    border-bottom: 1px solid rgba(15, 52, 96, 0.3);
    color: #aaa;
}

.cam-val {
    color: #e94560;
    font-family: monospace;
    font-weight: 600;
}

#camera-copy-feedback {
    color: #4caf50;
    font-size: 11px;
    margin-top: 6px;
    display: none;
    text-align: center;
}

/* ===== Scrollbar ===== */
#preset-grid::-webkit-scrollbar {
    width: 6px;
}

#preset-grid::-webkit-scrollbar-track {
    background: #16213e;
}

#preset-grid::-webkit-scrollbar-thumb {
    background: #0f3460;
    border-radius: 3px;
}

#preset-grid::-webkit-scrollbar-thumb:hover {
    background: #e94560;
}
